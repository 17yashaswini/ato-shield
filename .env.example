# ================================
# ATO Shield — Environment Variables
# ================================
# Copy this to .env.local (frontend) and .env (backend)
# NEVER commit actual keys to git!

# ---------- FRONTEND (.env.local) ----------

# Clerk — get from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000


# ---------- BACKEND (.env) ----------

# MongoDB Atlas — get from https://cloud.mongodb.com
# Local MongoDB (for dev): mongodb://localhost:27017
MONGODB_URL=mongodb://localhost:27017
DB_NAME=ato_shield

# App secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=REPLACE_WITH_RANDOM_SECRET

# Clerk secret (same as frontend)
CLERK_SECRET_KEY=sk_test_REPLACE_ME
